# ── App ───────────────────────────────────────────────────────────────────
APP_NAME=Fluento
APP_VERSION=0.1.0
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────
# SQLite for development — file will be created automatically
DATABASE_URL=sqlite:///./fluento.db

# ── Whisper ───────────────────────────────────────────────────────────────
# tiny = fastest, least accurate (good for testing)
# base = good balance for development
# small / medium / large = better accuracy, slower, more RAM
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── LLM ───────────────────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.3

# ── Auth (leave blank until Google OAuth is implemented) ──────────────────
JWT_SECRET=change-this-to-a-random-string-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of exact frontend origins allowed to call the API.
# In production set this to your deployed frontend URL(s), e.g.:
#   CORS_ORIGINS=https://fluento-v1.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000
# Regex for additional allowed origins (additive to CORS_ORIGINS). The default
# matches every Vercel deploy for this project so a Vercel rename never breaks
# CORS. Set to an empty value to disable.
CORS_ORIGIN_REGEX=https://fluento.*\.vercel\.app

# ── Audio ─────────────────────────────────────────────────────────────────
AUDIO_UPLOAD_DIR=./audio_uploads
MAX_AUDIO_SIZE_MB=25
